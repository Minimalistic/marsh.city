---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const { title = 'marsh.city', description = "Jason Marsh's corner of the internet" } = Astro.props;
const fullTitle = title === 'marsh.city' ? title : `${title} — marsh.city`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="layout">
      <nav class="site-nav">
        <a href="/" class="brand">marsh.city</a>
        <div class="links">
          <a href="/projects/">projects</a>
          <a href="/posts/">posts</a>
          <a href="/now/">now</a>
          <a href="/about/">about</a>
        </div>
      </nav>

      <main>
        <slot />
      </main>

      <footer class="site-foot">
        <span>© Jason Marsh</span>
        <span><a href="https://github.com/Minimalistic/marsh.city">source</a></span>
      </footer>
    </div>

    <script is:inline>
      // fireflies — gentle glowing dots drifting across the page
      (() => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const COUNT = 12;
        const container = document.body;

        for (let i = 0; i < COUNT; i++) {
          const el = document.createElement('div');
          el.className = 'firefly';
          container.appendChild(el);
          animateFirefly(el, true);
        }

        function animateFirefly(el, first) {
          // random start position
          const x = Math.random() * window.innerWidth;
          const y = Math.random() * window.innerHeight;
          el.style.left = x + 'px';
          el.style.top = y + 'px';

          // drift distance
          const dx = (Math.random() - 0.5) * 200;
          const dy = (Math.random() - 0.5) * 160;

          // timing
          const fadeIn = 800 + Math.random() * 1200;
          const glow = 2000 + Math.random() * 4000;
          const fadeOut = 800 + Math.random() * 1200;
          const totalDrift = fadeIn + glow + fadeOut;
          const delay = first ? Math.random() * 5000 : 200 + Math.random() * 3000;

          const size = 3 + Math.random() * 5;
          el.style.width = size + 'px';
          el.style.height = size + 'px';

          setTimeout(() => {
            const start = performance.now();
            function tick(now) {
              const elapsed = now - start;
              const progress = Math.min(elapsed / totalDrift, 1);

              // ease position
              const ease = progress;
              el.style.transform = `translate(${dx * ease}px, ${dy * ease}px)`;

              // fade envelope: in → hold → out
              let opacity;
              if (elapsed < fadeIn) {
                opacity = (elapsed / fadeIn) * 0.7;
              } else if (elapsed < fadeIn + glow) {
                // gentle pulse while glowing
                const t = (elapsed - fadeIn) / glow;
                opacity = 0.5 + 0.2 * Math.sin(t * Math.PI * 2);
              } else {
                opacity = 0.7 * (1 - (elapsed - fadeIn - glow) / fadeOut);
              }
              el.style.opacity = Math.max(0, opacity);

              if (progress < 1) {
                requestAnimationFrame(tick);
              } else {
                el.style.opacity = 0;
                animateFirefly(el, false);
              }
            }
            requestAnimationFrame(tick);
          }, delay);
        }
      })();
    </script>

    <script is:inline>
      // client-side mermaid: transforms ```mermaid code blocks to rendered diagrams
      // is:inline prevents Astro from bundling — needed for dynamic CDN import
      (async () => {
        const blocks = document.querySelectorAll(
          'pre > code.language-mermaid, code.language-mermaid, pre.mermaid, pre[data-language="mermaid"]'
        );
        if (blocks.length === 0) return;
        try {
          const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
          const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          mermaid.initialize({ startOnLoad: false, theme: dark ? 'dark' : 'neutral', fontFamily: 'Inter, sans-serif' });
          blocks.forEach((el, i) => {
            const target = el.closest('pre') || el;
            const div = document.createElement('div');
            div.className = 'mermaid';
            div.id = `mermaid-${i}`;
            div.textContent = target.textContent || '';
            target.replaceWith(div);
          });
          await mermaid.run();
        } catch (e) {
          console.error('Mermaid failed to load:', e);
        }
      })();
    </script>
  </body>
</html>
