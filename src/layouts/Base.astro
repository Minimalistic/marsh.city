---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const { title = 'marsh.city', description = "Jason Marsh's corner of the internet" } = Astro.props;
const fullTitle = title === 'marsh.city' ? title : `${title} — marsh.city`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- monstera canopy overlay -->
    <div class="canopy" aria-hidden="true">
      <svg class="canopy-leaf leaf-1" viewBox="0 0 400 500" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g>
          <path d="M200 20C150 15 60 80 30 200C15 270 30 350 70 410C110 470 170 500 210 500
                   C210 500 180 420 185 340C190 260 220 200 260 170C300 140 340 130 340 130
                   C340 130 290 110 260 70C240 45 220 25 200 20Z" fill="currentColor"/>
          <path d="M160 200C175 270 185 340 210 500" stroke="var(--bg)" stroke-width="2.5" opacity="0.3" fill="none"/>
          <path d="M160 200C120 250 80 310 70 410" stroke="var(--bg)" stroke-width="1.8" opacity="0.2" fill="none"/>
          <path d="M160 200C200 215 240 195 260 170" stroke="var(--bg)" stroke-width="1.8" opacity="0.2" fill="none"/>
          <path d="M160 200C210 175 270 155 340 130" stroke="var(--bg)" stroke-width="1.5" opacity="0.15" fill="none"/>
          <path d="M160 200C175 155 210 90 260 70" stroke="var(--bg)" stroke-width="1.5" opacity="0.15" fill="none"/>
          <path d="M160 200C140 160 180 60 200 20" stroke="var(--bg)" stroke-width="1.2" opacity="0.12" fill="none"/>
          <ellipse cx="110" cy="310" rx="20" ry="35" transform="rotate(-10 110 310)" fill="var(--bg)"/>
          <ellipse cx="80" cy="380" rx="14" ry="24" transform="rotate(-15 80 380)" fill="var(--bg)"/>
          <ellipse cx="190" cy="270" rx="16" ry="28" transform="rotate(12 190 270)" fill="var(--bg)"/>
          <ellipse cx="230" cy="200" rx="12" ry="20" transform="rotate(25 230 200)" fill="var(--bg)"/>
          <ellipse cx="140" cy="370" rx="11" ry="18" transform="rotate(-5 140 370)" fill="var(--bg)"/>
          <ellipse cx="250" cy="150" rx="10" ry="15" transform="rotate(35 250 150)" fill="var(--bg)"/>
        </g>
      </svg>
      <svg class="canopy-leaf leaf-2" viewBox="0 0 400 500" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g>
          <path d="M200 20C150 15 60 80 30 200C15 270 30 350 70 410C110 470 170 500 210 500
                   C210 500 180 420 185 340C190 260 220 200 260 170C300 140 340 130 340 130
                   C340 130 290 110 260 70C240 45 220 25 200 20Z" fill="currentColor"/>
          <path d="M160 200C175 270 185 340 210 500" stroke="var(--bg)" stroke-width="2.5" opacity="0.3" fill="none"/>
          <path d="M160 200C120 250 80 310 70 410" stroke="var(--bg)" stroke-width="1.8" opacity="0.2" fill="none"/>
          <path d="M160 200C200 215 240 195 260 170" stroke="var(--bg)" stroke-width="1.8" opacity="0.2" fill="none"/>
          <ellipse cx="110" cy="310" rx="20" ry="35" transform="rotate(-10 110 310)" fill="var(--bg)"/>
          <ellipse cx="190" cy="270" rx="16" ry="28" transform="rotate(12 190 270)" fill="var(--bg)"/>
          <ellipse cx="80" cy="380" rx="14" ry="24" transform="rotate(-15 80 380)" fill="var(--bg)"/>
          <ellipse cx="230" cy="200" rx="12" ry="20" transform="rotate(25 230 200)" fill="var(--bg)"/>
        </g>
      </svg>
      <svg class="canopy-leaf leaf-3" viewBox="0 0 400 500" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g>
          <path d="M200 20C150 15 60 80 30 200C15 270 30 350 70 410C110 470 170 500 210 500
                   C210 500 180 420 185 340C190 260 220 200 260 170C300 140 340 130 340 130
                   C340 130 290 110 260 70C240 45 220 25 200 20Z" fill="currentColor"/>
          <path d="M160 200C175 270 185 340 210 500" stroke="var(--bg)" stroke-width="2.5" opacity="0.3" fill="none"/>
          <path d="M160 200C120 250 80 310 70 410" stroke="var(--bg)" stroke-width="1.8" opacity="0.2" fill="none"/>
          <path d="M160 200C200 215 240 195 260 170" stroke="var(--bg)" stroke-width="1.8" opacity="0.2" fill="none"/>
          <path d="M160 200C210 175 270 155 340 130" stroke="var(--bg)" stroke-width="1.5" opacity="0.15" fill="none"/>
          <ellipse cx="110" cy="310" rx="20" ry="35" transform="rotate(-10 110 310)" fill="var(--bg)"/>
          <ellipse cx="190" cy="270" rx="16" ry="28" transform="rotate(12 190 270)" fill="var(--bg)"/>
          <ellipse cx="140" cy="370" rx="11" ry="18" transform="rotate(-5 140 370)" fill="var(--bg)"/>
        </g>
      </svg>
    </div>

    <div class="layout">
      <nav class="site-nav">
        <a href="/" class="brand">
          <svg class="brand-leaf" viewBox="0 0 24 28" fill="currentColor" aria-hidden="true">
            <path d="M12 2C8 2 3 7 2 14C1.5 18 3 23 6 26C6 26 5.5 20 7 16C8.5 12 11 9 13 8
                     C15 7 17 7 17 7C17 7 15 5 13 3.5C12.5 2.8 12 2 12 2Z" opacity="0.9"/>
            <path d="M9.5 14C10 17 10.5 20 6 26" stroke="var(--bg)" stroke-width="0.6" fill="none" opacity="0.4"/>
            <path d="M9.5 14C8 16 5.5 19 2 14" stroke="var(--bg)" stroke-width="0.5" fill="none" opacity="0.3"/>
            <path d="M9.5 14C11 13 13 10 13 8" stroke="var(--bg)" stroke-width="0.5" fill="none" opacity="0.3"/>
            <ellipse cx="7" cy="18" rx="1.5" ry="2.5" transform="rotate(-10 7 18)" fill="var(--bg)" opacity="0.25"/>
          </svg>
          marsh.city
        </a>
        <div class="links">
          <a href="/projects/">projects</a>
          <a href="/posts/">posts</a>
          <a href="/now/">now</a>
          <a href="/about/">about</a>
        </div>
      </nav>

      <main>
        <slot />
      </main>

      <footer class="site-foot">
        <span>© Jason Marsh</span>
        <span><a href="https://github.com/Minimalistic/marsh.city">source</a></span>
      </footer>
    </div>

    <script is:inline>
      // client-side mermaid: transforms ```mermaid code blocks to rendered diagrams
      // is:inline prevents Astro from bundling — needed for dynamic CDN import
      (async () => {
        const blocks = document.querySelectorAll(
          'pre > code.language-mermaid, code.language-mermaid, pre.mermaid, pre[data-language="mermaid"]'
        );
        if (blocks.length === 0) return;
        try {
          const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
          const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          mermaid.initialize({ startOnLoad: false, theme: dark ? 'dark' : 'neutral', fontFamily: 'Inter, sans-serif' });
          blocks.forEach((el, i) => {
            const target = el.closest('pre') || el;
            const div = document.createElement('div');
            div.className = 'mermaid';
            div.id = `mermaid-${i}`;
            div.textContent = target.textContent || '';
            target.replaceWith(div);
          });
          await mermaid.run();
        } catch (e) {
          console.error('Mermaid failed to load:', e);
        }
      })();
    </script>
    <script is:inline>
      // parallax drift for canopy leaves on scroll
      (function() {
        const leaves = document.querySelectorAll('.canopy-leaf');
        if (!leaves.length || window.matchMedia('(max-width: 600px)').matches) return;
        const speeds = [0.03, -0.02, 0.015];
        let ticking = false;
        window.addEventListener('scroll', function() {
          if (!ticking) {
            requestAnimationFrame(function() {
              const y = window.scrollY;
              leaves.forEach(function(leaf, i) {
                const speed = speeds[i] || 0.02;
                leaf.style.translate = '0 ' + (y * speed) + 'px';
              });
              ticking = false;
            });
            ticking = true;
          }
        });
      })();
    </script>
  </body>
</html>
