---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const projects = (await getCollection('projects'))
  .sort((a, b) => (b.data.updated ?? new Date(0)).valueOf() - (a.data.updated ?? new Date(0)).valueOf())
  .slice(0, 6);
---
<Base description="Jason Marsh — developer, technologist, builder of AI-integrated tools.">
  <div class="hero">
    <h1>Jason Marsh</h1>
    <p class="subtitle">
      Developer and technologist in Duluth, MN. 13+ years in IT, directing
      technology at a nonprofit by day, shipping AI-integrated tools solo
      by night. From accessible kiosk apps to IoT hardware to recipe
      intelligence — I build the whole thing.
    </p>
  </div>

  <div class="section-header">
    <h2>Projects</h2>
    <a href="/projects/">View all</a>
  </div>
  {projects.map((p) => {
    const ago = p.data.updated ? (() => {
      const days = Math.floor((Date.now() - p.data.updated.valueOf()) / 86400000);
      if (days === 0) return 'today';
      if (days === 1) return 'yesterday';
      if (days < 30) return `${days}d ago`;
      if (days < 365) return `${Math.floor(days / 30)}mo ago`;
      return `${Math.floor(days / 365)}y ago`;
    })() : null;
    return (
      <a class="card" href={`/projects/${p.id}/`}>
        <h3>{p.data.title}<span class={`status status-${p.data.status}`}>{p.data.status}</span>{p.data.url && <span class="demo-badge">live demo</span>}</h3>
        <p class="meta">{p.data.description}</p>
        {ago && <p class="meta" style="margin-top:0.25rem;font-size:0.78rem;color:var(--fg-muted)">updated {ago}</p>}
        {p.data.tags && p.data.tags.length > 0 && (
          <div class="tags">
            {p.data.tags.map((t: string) => <span class="tag">{t}</span>)}
          </div>
        )}
      </a>
    );
  })}

  {posts.length > 0 && (
    <>
      <div class="section-header">
        <h2>Writing</h2>
        <a href="/posts/">View all</a>
      </div>
      {posts.map((p) => (
        <a class="card" href={`/posts/${p.id}/`}>
          <h3>{p.data.title}</h3>
          <p class="meta">{p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
        </a>
      ))}
    </>
  )}
</Base>
