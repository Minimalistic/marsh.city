---
import Post from '../../layouts/Post.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---
<Post title={project.data.title} description={project.data.description}>
  <div class="project-meta">
    <span class="status" aria-label={({ idea: 'Idea', wip: 'Work in progress', shipped: 'Shipped', archived: 'Archived' })[project.data.status]}>{project.data.status}</span>
    {project.data.repo && <a href={project.data.repo} class="project-link">repo</a>}
    {project.data.updated && <span class="meta">Updated {project.data.updated.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>}
  </div>
  {project.data.url && (
    <a href={project.data.url} class="live-demo-btn">Try the live demo</a>
  )}
  <p class="tagline">{project.data.description}</p>
  <Content />
</Post>
