---
import Base from '../layouts/Base.astro';
---
<Base title="Resume" description="Jason Marsh — Director of Technology, 13+ years IT, assistive technology, infrastructure, and solo development.">
  <div class="resume-top">
    <h1>Resume</h1>
    <button class="resume-download" onclick="window.print()" aria-label="Print resume or save as PDF">Save as PDF</button>
  </div>

  <div class="prose">
    <p class="resume-intro">
      Director of Technology with 13+ years of IT experience spanning infrastructure
      management, assistive technology services, and team leadership. Promoted three
      times in five years based on demonstrated results, including growing AT service
      revenue from $17K to over $200K annually. Combines hands-on technical expertise
      across Microsoft 365/Azure, Windows/Linux, and networking with an ATACP
      certification for assistive technology assessments.
    </p>

    <h2>Experience</h2>

    <div class="resume-entry">
      <div class="resume-header">
        <strong>Director of Technology</strong>
        <span class="meta">May 2025 – Present</span>
      </div>
      <div class="resume-org">Lighthouse Center for Vital Living — Duluth, MN</div>
      <ul>
        <li>Lead IT and Assistive Technology divisions for a nonprofit serving people with disabilities and aging populations, overseeing infrastructure, AT services, and an AT lending library partnered with the Minnesota STAR Program</li>
        <li>One of four organizational leaders reporting to the Executive Director; contribute to strategic planning, budgeting, and cross-department decision-making</li>
        <li>Manage a team of four including an IT support specialist, an ATP, and two AT specialists</li>
        <li>Restructured AT billing operations and coached staff on proposals and invoicing, growing annual service revenue from $17K to over $200K</li>
        <li>Conduct AT assessments and recommend AI-powered solutions including Be My Eyes, Seeing AI, OrCam Reader, and Meta Ray-Ban smart glasses</li>
      </ul>
    </div>

    <div class="resume-entry">
      <div class="resume-header">
        <strong>IT Manager & Accessibility Specialist</strong>
        <span class="meta">Mar 2021 – May 2025</span>
      </div>
      <div class="resume-org">Lighthouse Center for Vital Living — Duluth, MN</div>
      <ul>
        <li>Conducted full systems audit; established documentation and standardized processes organization-wide</li>
        <li>Led cloud migration to Microsoft 365 and Azure AD during a building relocation, reducing annual IT costs by $15,000+</li>
        <li>Established disaster recovery procedures, security protocols, and a technology replacement plan</li>
        <li>Managed endpoints via Microsoft Intune (Windows) and IBM MaaS360 (iOS/Android) for MDM, app deployment, and compliance</li>
        <li>Built centralized request tracking system to streamline IT and AT workflows</li>
      </ul>
    </div>

    <div class="resume-entry">
      <div class="resume-header">
        <strong>Accessible Technology Specialist</strong>
        <span class="meta">Oct 2020 – Mar 2021</span>
      </div>
      <div class="resume-org">Lighthouse Center for Vital Living — Duluth, MN</div>
      <ul>
        <li>Evaluated and configured assistive technology — screen readers, magnification tools, wearable devices — for clients with disabilities and aging-related needs</li>
        <li>Trained staff and clients on AT usage; attended ATIA and Closing The Gap conferences</li>
      </ul>
    </div>

    <div class="resume-entry">
      <div class="resume-header">
        <strong>Technical Administrator</strong>
        <span class="meta">Nov 2012 – Nov 2020</span>
      </div>
      <div class="resume-org">Westside Pet Clinic — Duluth, MN</div>
      <ul>
        <li>Sole IT administrator for eight years, managing all hardware, networking, and software</li>
        <li>Led transition from paper records to electronic medical systems; developed custom internal workflows</li>
      </ul>
    </div>

    <h2>Independent Projects</h2>
    <ul class="projects-compact">
      <li><a href="/projects/mealdeck/">MealDeck</a> — meal planning with AI recipe adaptation, voice-controlled cook mode, smart grocery grouping</li>
      <li><a href="/projects/radiogridxl/">RadioGridXL</a> — zero-dependency accessible radio streaming app, WCAG AA, deployed to older adults at my organization</li>
      <li><a href="/projects/petfeedr/">PetFeedr</a> — Raspberry Pi automated pet feeder with web interface, scheduling, and feed-time randomization</li>
      <li><a href="/projects/echoetcher/">EchoEtcher</a> — voice-to-structured-notes pipeline using local Whisper and LLM processing</li>
      <li>InfoVault (in development) — handheld device using camera-based LLM identification to read text aloud and describe objects for users with vision loss</li>
    </ul>

    <h2>Technical Skills</h2>
    <dl class="resume-skills-compact">
      <div><dt>Infrastructure</dt><dd>Microsoft 365, Azure AD, Active Directory, Windows Server, Hyper-V, VMware/ESXi, Proxmox VE, DNS/DHCP, VPN, Firewall Management</dd></div>
      <div><dt>Endpoint & Security</dt><dd>Microsoft Intune, IBM MaaS360, Linux Administration, Disaster Recovery, Incident Response, Cloud Security</dd></div>
      <div><dt>Development</dt><dd>Python, JavaScript, Node.js, Express, PowerShell, HTML/CSS, SQL, LLM Integration & Prompt Engineering, Computer Vision, Git, Arduino/ESP-8266</dd></div>
      <div><dt>Platforms</dt><dd>SharePoint, Microsoft Teams, ServiceNow, FreshDesk, Docker, Tailscale, GitHub Actions</dd></div>
    </dl>

    <h2>Education & Certifications</h2>
    <table class="resume-edu">
      <tr><td><strong>Assistive Technology Applications Certificate (ATACP)</strong></td><td>CSUN</td><td class="meta">2025</td></tr>
      <tr><td><strong>Network Admin & Cybersecurity</strong> (coursework)</td><td>Lake Superior College</td><td class="meta">2022</td></tr>
      <tr><td><strong>Full Stack Web Developer Nanodegree</strong></td><td>Udacity</td><td class="meta">2018</td></tr>
      <tr><td><strong>B.S. Video Game Art & Design</strong></td><td>Art Institute of Pittsburgh</td><td class="meta">2010</td></tr>
    </table>

    <h2>Get in touch</h2>
    <div class="resume-contact">
      <ul>
        <li>Email: <a href="mailto:regularlyjason@icloud.com">regularlyjason@icloud.com</a></li>
        <li>LinkedIn: <a href="https://www.linkedin.com/in/jason-marsh">jason-marsh</a></li>
        <li>GitHub: <a href="https://github.com/Minimalistic">Minimalistic</a></li>
      </ul>
      <div class="resume-qr">
        <img src="/qr.svg" alt="QR code linking to marsh.city" width="72" height="72" />
        <span>marsh.city</span>
      </div>
    </div>
  </div>
</Base>

<style>
  .resume-intro {
    font-size: 1.05rem;
    color: var(--fg-soft);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }
  .resume-entry {
    margin-bottom: 1rem;
  }
  .resume-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .resume-org {
    color: var(--fg-soft);
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }
  .resume-entry ul {
    margin-top: 0.25rem;
    margin-bottom: 0;
  }
  .resume-entry li {
    margin-bottom: 0.15rem;
  }
  .projects-compact {
    margin-top: 0.25rem;
  }
  .projects-compact li {
    margin-bottom: 0.25rem;
  }

  /* skills as inline definition list */
  .resume-skills-compact {
    margin: 0.5rem 0 1rem;
  }
  .resume-skills-compact div {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
    line-height: 1.5;
  }
  .resume-skills-compact dt {
    font-weight: 600;
    font-size: 0.85rem;
    min-width: 130px;
    flex-shrink: 0;
    color: var(--fg);
  }
  .resume-skills-compact dd {
    margin: 0;
    font-size: 0.88rem;
    color: var(--fg-soft);
  }

  /* education as compact table */
  .resume-edu {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 0.5rem 0 1rem;
  }
  .resume-edu td {
    padding: 0.3rem 0.5rem 0.3rem 0;
    vertical-align: baseline;
    border: none;
  }
  .resume-edu td:last-child {
    text-align: right;
    white-space: nowrap;
  }

  .resume-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .resume-top h1 {
    margin-bottom: 0;
  }
  .resume-download {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.45em 1.1em;
    border-radius: var(--radius-sm);
    background: var(--bg-elev2);
    color: var(--fg-soft);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .resume-download:hover {
    color: var(--leaf);
    border-color: var(--leaf);
    background: color-mix(in srgb, var(--leaf) 8%, var(--bg-elev2));
  }

  .resume-contact {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
  }
  .resume-contact ul {
    margin: 0;
  }
  .resume-qr {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .resume-qr img {
    border-radius: var(--radius-sm);
  }
  .resume-qr span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-muted);
  }
  @media (prefers-color-scheme: dark) {
    .resume-qr img {
      filter: invert(1);
    }
  }

  @media (max-width: 600px) {
    .resume-skills-compact div {
      flex-direction: column;
      gap: 0;
    }
    .resume-skills-compact dt {
      min-width: auto;
    }
    .resume-edu td:nth-child(2) {
      display: none;
    }
  }
</style>

<style is:global>
  @media print {
    nav.site-nav,
    footer.site-foot,
    .layout::before,
    body::after { display: none !important; }

    *, *::before, *::after {
      background: white !important;
      box-shadow: none !important;
    }
    body, .layout {
      color: #1a1a1a !important;
      padding: 0 !important;
      margin: 0 !important;
      max-width: none !important;
      font-size: 10.5pt !important;
      line-height: 1.45 !important;
    }

    .resume-top { display: block; }
    .resume-download { display: none; }

    .resume-top::before {
      content: 'Jason Marsh';
      display: block;
      font-family: var(--font-serif);
      font-size: 20pt;
      font-weight: 600;
      margin-bottom: 0.1em;
    }
    .resume-top::after {
      content: 'Duluth, MN \2022  regularlyjason@icloud.com \2022  linkedin.com/in/jason-marsh \2022  github.com/Minimalistic';
      display: block;
      font-size: 8.5pt;
      color: #555;
      margin-bottom: 0.75em;
    }
    h1 { display: none; }

    h2 {
      font-size: 11pt !important;
      margin-top: 0.9rem !important;
      margin-bottom: 0.4rem !important;
      border-color: #ccc !important;
      padding-bottom: 0.2rem !important;
    }
    .resume-intro {
      font-size: 9.5pt !important;
      color: #333 !important;
      margin-bottom: 0.5rem !important;
      line-height: 1.5 !important;
    }
    .resume-entry { margin-bottom: 0.5rem !important; }
    .resume-entry li { margin-bottom: 0 !important; font-size: 9.5pt; }
    .resume-org { font-size: 8.5pt !important; }
    .resume-skills-compact dt { font-size: 9pt !important; }
    .resume-skills-compact dd { font-size: 9pt !important; }
    .resume-skills-compact div { margin-bottom: 0.15rem !important; }
    .resume-edu { font-size: 9pt !important; }
    .resume-edu td { padding: 0.15rem 0.5rem 0.15rem 0 !important; }
    .projects-compact li { font-size: 9.5pt; margin-bottom: 0.1rem !important; }

    a { color: #1a1a1a !important; text-decoration: none !important; }
    a::after { display: none !important; }

    .prose ul, .prose ol { padding-left: 1rem !important; }
  }
</style>
