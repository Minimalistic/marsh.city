---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const items = await getCollection('playground');
---
<Base title="Playground">
  <h1>Playground</h1>
  <p class="tagline">Goofy experiments, tiny games, weekend toys. No promises of polish.</p>
  {items.length === 0 && <p style="color: var(--fg-soft);">Nothing here yet — but the soil is fertile.</p>}
  {items.map((p) => (
    <a class="card" href={p.data.url ?? `/playground/${p.id}/`}>
      <h3>{p.data.title}</h3>
      <p class="meta">{p.data.description}</p>
    </a>
  ))}
</Base>
